    <sql id="selectVo">
        select track_id, mold_code, product_spec, mold_type, surface_status, machine_type,
               machine_count, plan_machine_time, hot_machine_date, round_keep_time,
               hot_production, improve_record, hot_improve_person,
               hot_machine_station, hot_check_measure_data, hot_check_measure_image,
               spin_machine_date, spin_machine_station, spin_production, mold_modify_record, spin_improve_person,
               spin_front_distance_image,
               spin_improve_status,
               heat_receive_count, heat_transfer_count, heat_transfer_time, heat_flow_sheet_image,
               rough_machine_date, rough_production, rough_improve_person, improve_plan,
               fine_machine_date, fine_production, fine_improve_person, paint_machine_date, paint_production, paint_improve_person,
               paint_flow_sheet_image,
               impact_test_date, impact_test_result, test_description, test_close_status,
               complete_date, fail_product_trace, fail_analysis,
               production_summary, improve_measures, lessons_learned, all_process_done,
               create_by, create_time, update_by, update_time, del_flag, remark
        from tech_trial_track
    </sql>

    <select id="selectTechTrialTrackList" parameterType="TechTrialTrack" resultMap="TechTrialTrackResult">
        <include refid="selectVo"/>
        <where>
            <if test="moldCode != null and moldCode != ''"> and mold_code like concat('%', #{moldCode}, '%')</if>
            <if test="moldType != null and moldType != ''"> and mold_type = #{moldType}</if>
            <if test="surfaceStatus != null and surfaceStatus != ''"> and surface_status = #{surfaceStatus}</if>
            <if test="machineType != null and machineType != ''"> and machine_type = #{machineType}</if>
            <!-- allProcessDone=doing 查进行中；=done 查已完成（避免 OGNL 对中文转数字报错） -->
            <if test="allProcessDone == 'done'">
              and all_process_done = '是'
            </if>
            <if test="allProcessDone == 'doing'">
              and (all_process_done is null or all_process_done != '是')
            </if>
            and del_flag = '0'
        </where>
        order by track_id desc
    </select>

    <select id="selectTechTrialTrackByTrackId" parameterType="Long" resultMap="TechTrialTrackResult">
        <include refid="selectVo"/> where track_id = #{trackId}
    </select>

    <select id="selectTechTrialTrackByMoldCode" parameterType="String" resultMap="TechTrialTrackResult">
        <include refid="selectVo"/>
        where mold_code = #{moldCode} and del_flag = '0'
        order by track_id desc
        limit 1
    </select>

