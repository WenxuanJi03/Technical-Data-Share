            <if test="designLife != null">design_life,</if>
            <if test="currentCount != null">current_count,</if>
            <if test="manufactureDate != null">manufacture_date,</if>
            <if test="acceptanceDate != null">acceptance_date,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="delFlag != null">del_flag,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="moldCode != null and moldCode != ''">#{moldCode},</if>
            <if test="moldName != null and moldName != ''">#{moldName},</if>
