    </update>

    <delete id="deleteTechMoldByMoldId" parameterType="Long">
        delete from tech_mold where mold_id = #{moldId}
    </delete>

    <delete id="deleteTechMoldByMoldIds" parameterType="String">
        delete from tech_mold where mold_id in 
        <foreach item="moldId" collection="array" open="(" separator="," close=")">
            #{moldId}
        </foreach>
    </delete>
</mapper>