    <sql id="selectTechMoldVo">
        select mold_id, mold_code, mold_name, mold_type, project_id, product_name, specification, material, supplier, status, location, design_life, current_count, manufacture_date, acceptance_date, create_by, create_time, update_by, update_time, del_flag, remark from tech_mold
    </sql>

    <select id="selectTechMoldList" parameterType="TechMold" resultMap="TechMoldResult">
        <include refid="selectTechMoldVo"/>
        <where>  
            <if test="moldCode != null  and moldCode != ''"> and mold_code = #{moldCode}</if>
            <if test="moldName != null  and moldName != ''"> and mold_name like concat('%', #{moldName}, '%')</if>
            <if test="moldType != null  and moldType != ''"> and mold_type = #{moldType}</if>
            <if test="projectId != null "> and project_id = #{projectId}</if>
            <if test="productName != null  and productName != ''"> and product_name like concat('%', #{productName}, '%')</if>
            <if test="specification != null  and specification != ''"> and specification = #{specification}</if>
            <if test="material != null  and material != ''"> and material = #{material}</if>
            <if test="supplier != null  and supplier != ''"> and supplier = #{supplier}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
            <if test="location != null  and location != ''"> and location = #{location}</if>
            <if test="designLife != null "> and design_life = #{designLife}</if>
            <if test="currentCount != null "> and current_count = #{currentCount}</if>
            <if test="manufactureDate != null "> and manufacture_date = #{manufactureDate}</if>
            <if test="acceptanceDate != null "> and acceptance_date = #{acceptanceDate}</if>
        </where>
    </select>
    
    <select id="selectTechMoldByMoldId" parameterType="Long" resultMap="TechMoldResult">
        <include refid="selectTechMoldVo"/>
        where mold_id = #{moldId}
    </select>

    <insert id="insertTechMold" parameterType="TechMold" useGeneratedKeys="true" keyProperty="moldId">
        insert into tech_mold
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="moldCode != null and moldCode != ''">mold_code,</if>
            <if test="moldName != null and moldName != ''">mold_name,</if>
            <if test="moldType != null">mold_type,</if>
